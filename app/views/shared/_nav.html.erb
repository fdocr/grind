<header class="border-b border-border bg-card relative z-30">
  <div class="max-w-lg mx-auto px-4 py-4 flex items-center justify-between">
    <%= link_to root_path, class: "text-xl font-bold text-primary-700 tracking-tight" do %>
      Grind
    <% end %>

    <div data-controller="nav-menu" class="ui-nav-menu relative">
      <button type="button"
              name="menu"
              aria-label="Open menu"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls="nav-menu-panel"
              class="ui-icon-btn"
              data-testid="nav-menu-button"
              data-nav-menu-target="button"
              data-action="click->nav-menu#toggle">
        <%= render "shared/svg/menu", class: "w-5 h-5" %>
      </button>

      <div id="nav-menu-panel"
           data-nav-menu-target="menu"
           data-testid="nav-menu-panel"
           class="ui-nav-menu-panel hidden"
           role="menu"
           aria-label="Main navigation"
           aria-hidden="true">
        <%= render "shared/nav_links" %>
      </div>
    </div>
  </div>
</header>
