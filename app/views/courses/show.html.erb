<%# Sheet overlay only when loaded into the homepage Turbo Frame.
    Hotwire Native and full-page visits get a normal document preview. %>
<% use_sheet = !hotwire_native_app? && request.headers["Turbo-Frame"].present? %>

<% if use_sheet %>
  <%= turbo_frame_tag "course_modal" do %>
    <%= render "courses/preview",
          course: @course,
          holes: @holes,
          tee_names: @tee_names,
          active_tee: @active_tee,
          sheet: true %>
  <% end %>
<% else %>
  <%= render "courses/preview",
        course: @course,
        holes: @holes,
        tee_names: @tee_names,
        active_tee: @active_tee,
        sheet: false %>
<% end %>
