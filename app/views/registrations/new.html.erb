<% content_for :seo_title, "Create account" %>

<div class="space-y-6">
  <header class="space-y-1">
    <h1 class="text-xl font-bold text-foreground">Create account</h1>
    <p class="text-sm text-muted-foreground">Track your rounds and get recap emails automatically.</p>
  </header>

  <%= render "ui/card", padding: :sm do %>
    <%= form_with model: @user, url: registration_path, class: "space-y-4", data: { turbo: false } do |f| %>
      <%= render "ui/input",
            form: f, field: :email, type: :email, label: "Email",
            placeholder: "you@example.com",
            required: true, autofocus: true, autocomplete: "email" %>

      <%= render "ui/input",
            form: f, field: :password, type: :password, label: "Password",
            placeholder: "••••••••",
            required: true, autocomplete: "new-password",
            minlength: 8,
            hint: "At least 8 characters" %>

      <%= render "ui/input",
            form: f, field: :password_confirmation, type: :password, label: "Confirm password",
            placeholder: "••••••••",
            required: true, autocomplete: "new-password",
            minlength: 8 %>

      <%= render "shared/turnstile" %>

      <button type="submit" class="ui-btn-primary ui-btn-md w-full">Create account</button>
    <% end %>
  <% end %>

  <p class="text-sm text-muted-foreground text-center">
    Already have an account?
    <%= link_to "Sign in", new_session_path, class: "ui-btn-link" %>
  </p>
</div>
