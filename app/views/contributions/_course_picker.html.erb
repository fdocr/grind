<section class="space-y-3">
  <h2 class="text-lg font-semibold">Select course</h2>

  <% if @selected_course %>
    <%= render "ui/card", padding: :sm do %>
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="font-medium text-foreground"><%= @selected_course.name %></p>
          <p class="text-sm text-muted-foreground mt-0.5"><%= @selected_course.location_label %></p>
        </div>
        <%= link_to "Change course", contribute_path, class: "ui-btn-link shrink-0 text-sm" %>
      </div>
    <% end %>
  <% else %>
    <%= turbo_frame_tag "contribution_course" do %>
      <%= render "ui/search_field",
            url: contribute_path,
            value: @query,
            frame: "contribution_course",
            placeholder: "Search your course",
            submit_text: "Search" %>

      <% if @courses&.any? %>
        <div class="grid grid-cols-1 gap-3 mt-3">
          <% @courses.each do |course| %>
            <%= link_to contribute_path(course_id: course.id), class: "block", data: { turbo_frame: "_top" } do %>
              <%= render "ui/card", padding: :sm, extra_class: "hover:border-primary-300 transition-colors" do %>
                <h3 class="font-semibold text-foreground"><%= course.name %></h3>
                <p class="text-sm text-muted-foreground mt-1"><%= course.location_label %></p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% elsif @query.present? %>
        <div class="mt-3">
          <%= render "ui/empty_state",
                title: "No courses found",
                message: "Try a different search, or request a new course instead.",
                icon: "search",
                compact: true,
                action: link_to("Add missing course", contribute_path(kind: "new_course"), class: "ui-btn-secondary ui-btn-sm") %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</section>
