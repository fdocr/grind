<%# locals: (pagy:, path: nil, params: {}) %>
<% return unless pagy.pages > 1 %>

<div class="flex items-center justify-center gap-2 pt-4 border-t border-border">
  <% if pagy.previous %>
    <% prev_params = params.merge(page: pagy.previous) %>
    <% if path %>
      <%= link_to "Previous", path.call(prev_params), class: "ui-btn-secondary ui-btn-sm", data: { turbo: false } %>
    <% else %>
      <%= link_to "Previous", url_for(prev_params), class: "ui-btn-secondary ui-btn-sm", data: { turbo: false } %>
    <% end %>
  <% end %>

  <span class="text-sm text-muted-foreground px-2">
    Page <%= pagy.page %> of <%= pagy.pages %>
  </span>

  <% if pagy.next %>
    <% next_params = params.merge(page: pagy.next) %>
    <% if path %>
      <%= link_to "Next", path.call(next_params), class: "ui-btn-secondary ui-btn-sm", data: { turbo: false } %>
    <% else %>
      <%= link_to "Next", url_for(next_params), class: "ui-btn-secondary ui-btn-sm", data: { turbo: false } %>
    <% end %>
  <% end %>
</div>
