<%# locals: (course:, holes:, tee_names:, active_tee:) %>
<% unit = course.metric? ? "m" : "yds" %>
<% front = holes.select { |hole| hole.number <= 9 } %>
<% back = holes.select { |hole| hole.number > 9 } %>

<%= render "ui/card", padding: :sm, extra_class: "overflow-hidden" do %>
  <div data-controller="tee-select"
       data-tee-select-tees-value="<%= course.tees.to_json %>"
       data-tee-select-active-value="<%= active_tee %>">
    <% if tee_names.size > 1 %>
      <div class="mb-4">
        <p class="ui-label mb-2">Select tee</p>
        <div class="ui-segmented" role="group">
          <% tee_names.each do |name| %>
            <button type="button"
                    class="ui-segmented-option"
                    data-tee-select-target="option"
                    data-value="<%= name %>"
                    data-state="<%= name == active_tee ? "active" : "inactive" %>"
                    data-action="tee-select#select">
              <%= name.titleize %>
            </button>
          <% end %>
        </div>
      </div>
    <% else %>
      <span class="ui-badge ui-badge-primary mb-4 inline-block"><%= active_tee.titleize %> tee</span>
    <% end %>

    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground mb-4">
      <span>Rating <span class="font-medium text-foreground" data-tee-select-target="rating">—</span></span>
      <span>Slope <span class="font-medium text-foreground" data-tee-select-target="slope">—</span></span>
      <span>Par <span class="font-medium text-foreground"><%= course.total_par %></span></span>
    </div>

    <div class="min-w-0 space-y-4">
      <% [ [ "Front nine", front, 0 ], [ "Back nine", back, 9 ] ].each do |label, nine, offset| %>
        <% next if nine.empty? %>
        <div>
          <h4 class="text-sm font-semibold mb-2 text-muted-foreground"><%= label %></h4>
          <div class="ui-scorecard-scroll">
            <table class="ui-scorecard-table">
              <tr>
                <th>Hole</th>
                <% nine.each do |hole| %><th><%= hole.number %></th><% end %>
                <th>Total</th>
              </tr>
              <tr>
                <td>Par</td>
                <% nine.each do |hole| %><td><%= hole.par %></td><% end %>
                <td><%= nine.sum(&:par) %></td>
              </tr>
              <tr>
                <td>Hcp</td>
                <% nine.each do |hole| %><td><%= hole.handicap %></td><% end %>
                <td></td>
              </tr>
              <tr>
                <td><%= unit.titleize %></td>
                <% nine.each do |hole| %>
                  <td data-tee-select-target="yardage" data-hole="<%= hole.number %>">—</td>
                <% end %>
                <td data-tee-select-target="<%= offset.zero? ? "totalOut" : "totalIn" %>">—</td>
              </tr>
            </table>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
