<% front = holes.select { |hole| hole.number <= 9 } %>
<% back = holes.select { |hole| hole.number > 9 } %>

<% [ [ "Front nine", front ], [ "Back nine", back ] ].each do |label, nine_holes| %>
  <% next if nine_holes.empty? %>
  <h2 class="scorecard-heading"><%= label %></h2>
  <table class="scorecard">
    <thead>
      <tr>
        <th>Hole</th>
        <% nine_holes.each do |hole| %>
          <th><%= hole.number %></th>
        <% end %>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <th>Par</th>
        <% nine_holes.each do |hole| %>
          <td><%= hole.par %></td>
        <% end %>
        <td><%= nine_holes.sum(&:par) %></td>
      </tr>
      <tr>
        <th>Hcp</th>
        <% nine_holes.each do |hole| %>
          <td><%= hole.handicap %></td>
        <% end %>
        <td></td>
      </tr>
      <% if round.tee.present? %>
        <tr>
          <th><%= round.course.metric? ? "M" : "Yds" %></th>
          <% nine_holes.each do |hole| %>
            <td><%= round.tee_yardage(hole.number) || "·" %></td>
          <% end %>
          <% yard_total = nine_holes.sum { |hole| round.tee_yardage(hole.number).to_i } %>
          <td><%= yard_total.zero? ? "·" : yard_total %></td>
        </tr>
      <% end %>
      <tr>
        <th>Score</th>
        <% nine_holes.each do |hole| %>
          <% entry = round.hole_scores[hole.number.to_s] || round.hole_scores[hole.number] %>
          <td><%= entry&.dig("gross") || "·" %></td>
        <% end %>
        <td>
          <% total = nine_holes.sum do |hole|
               entry = round.hole_scores[hole.number.to_s] || round.hole_scores[hole.number]
               entry&.dig("gross").to_i
             end %>
          <%= total.zero? ? "·" : total %>
        </td>
      </tr>
    </tbody>
  </table>
<% end %>
