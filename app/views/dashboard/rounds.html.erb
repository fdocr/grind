<%= turbo_frame_tag "dashboard-rounds" do %>
  <% if @rounds.any? %>
    <div class="space-y-3">
      <% @rounds.each do |round| %>
        <%= link_to round_path(round.token), class: "block", data: { turbo_frame: "_top" } do %>
          <%= render "ui/card", padding: :sm do %>
            <div class="flex items-center justify-between gap-3">
              <div class="min-w-0">
                <p class="font-medium text-foreground truncate"><%= round.course.name %></p>
                <p class="text-sm text-muted-foreground">
                  <%= round.finished_at&.strftime("%b %-d, %Y") %>
                  <% if round.tee_label %>
                    · <%= round.tee_label %> tee
                  <% end %>
                </p>
              </div>
              <p class="text-lg font-bold text-primary-600 shrink-0"><%= format_score_to_par(round.score_to_par) %></p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render "ui/pagination", pagy: @pagy, path: ->(params) { dashboard_rounds_path(params) }, frame: "dashboard-rounds" %>
  <% else %>
    <%= render "ui/empty_state",
          title: "No rounds yet",
          message: "Finish a round while signed in and it will show up here.",
          icon: "scorecard" %>
  <% end %>
<% end %>
