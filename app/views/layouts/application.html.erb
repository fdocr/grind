<!DOCTYPE html>
<html lang="en" class="<%= "h-full" if @native_modal %>">
  <head>
    <title><%= seo_page_title %></title>
    <%# viewport-fit=cover lets the PWA/browser draw into the safe areas, but inside
        a Hotwire Native web view it suppresses the automatic top inset and renders
        content under the native nav bar, so only opt into it outside the apps. %>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no<%= ", viewport-fit=cover" unless hotwire_native_app? %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#276f54">
    <%= render "shared/meta_tags" %>
    <%= render "shared/json_ld" %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Load once for the whole session. Widgets are rendered explicitly via
        the turnstile Stimulus controller (Turbo Frame / modal-safe). %>
    <% if ENV["CLOUDFLARE_TURNSTILE_SITE_KEY"].present? %>
      <%= tag.script src: "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit", async: true, defer: true %>
    <% end %>

    <!-- Privacy-friendly analytics by Plausible -->
    <% if ENV["PLAUSIBLE_URL"].present? %>
      <script async src="<%= ENV["PLAUSIBLE_URL"] %>"></script>
      <script>
        window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
        plausible.init()
      </script>
    <% end %>
  </head>

  <%# Native modals size to the WKWebView (already below the nav bar). Prefer
      h-full over 100dvh so the card isn't clipped by an oversized viewport. %>
  <body class="min-h-screen touch-manipulation<%= " overflow-hidden h-full" if @native_modal %>">
    <%# Native apps provide their own navigation bar. Instead of the web header
        they get a bridge-driven menu opened from a native hamburger button.
        Native modal pages skip the menu so the sheet chrome stays clean. %>
    <% if hotwire_native_app? %>
      <%= render "shared/native_menu" unless @native_modal %>
    <% else %>
      <%= render "shared/nav" %>
    <% end %>

    <main class="<%= @native_modal ? "max-w-lg mx-auto px-4 pt-3 pb-8 h-full flex flex-col overflow-hidden" : "max-w-lg mx-auto px-4 py-6 pb-24" %>">
      <% unless @native_modal %>
        <%= render "shared/connection_banner" %>
        <div id="flash" class="mb-4">
          <%= render "shared/flash" %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
