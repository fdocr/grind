<%# locals: (course:) %>
<% if course.coordinates? %>
  <% content_for :head do %>
    <%= stylesheet_link_tag "leaflet", "data-turbo-track": "reload" %>
  <% end %>
<% end %>

<section>
  <div class="flex items-center justify-between gap-3 mb-3">
    <h2 class="text-lg font-semibold">OpenStreetMap</h2>
    <%= render "ui/badge", text: course.osm_status_label, tone: osm_status_tone(course) %>
  </div>

  <%= render "ui/card", padding: :sm do %>
    <div class="space-y-4">
      <div class="flex flex-wrap items-center justify-between gap-3 text-sm">
        <p class="text-muted-foreground">
          <span class="font-medium text-foreground"><%= course.green_holes_count %></span> of 18 holes have green geometry.
        </p>
        <% if course.osm_synced_at.present? %>
          <p class="text-muted-foreground">Last synced <%= time_ago_in_words(course.osm_synced_at) %> ago</p>
        <% end %>
      </div>

      <% if course.coordinates? %>
        <div class="overflow-hidden rounded-lg border border-border">
          <div data-controller="map-embed"
               data-map-embed-center-value="<%= [ course.latitude.to_f, course.longitude.to_f ].to_json %>"
               data-map-embed-tile-url-value="<%= satellite_tile_url %>"
               data-map-embed-tile-attribution-value="<%= satellite_tile_attribution %>"
               data-map-embed-zoom-value="16"
               class="h-64 w-full z-0"
               role="img"
               aria-label="Satellite map of <%= course.name %>"></div>
        </div>
        <p class="text-[11px] text-muted-foreground text-center"><%= satellite_tile_attribution %> · Map data © OpenStreetMap contributors</p>

        <% green_holes = course.holes.select(&:green?) %>
        <% if green_holes.any? %>
          <div>
            <p class="ui-label mb-2">Holes with green data</p>
            <div class="flex flex-wrap gap-2">
              <% green_holes.each do |hole| %>
                <span class="ui-badge ui-badge-neutral text-xs">Hole <%= hole.number %></span>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="flex flex-col gap-2">
          <%= link_to "Calibrate greens", edit_admin_course_greens_path(course), class: "ui-btn-primary ui-btn-md w-full text-center" %>
          <%= button_to "Sync from OpenStreetMap",
                sync_osm_admin_course_path(course),
                method: :post,
                class: "ui-btn-secondary ui-btn-md w-full",
                form: { data: { turbo: false } } %>
        </div>
      <% else %>
        <%= render "ui/banner",
              tone: :info,
              title: "No coordinates",
              message: "Add latitude and longitude on the edit page to show the map and sync green geometry." %>
      <% end %>
    </div>
  <% end %>
</section>
