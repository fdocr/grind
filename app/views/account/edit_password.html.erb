<% content_for :seo_title, "Change password" %>

<div class="space-y-6">
  <header class="space-y-1">
    <h1 class="text-xl font-bold text-foreground">Change password</h1>
    <p class="text-sm text-muted-foreground">Update your account password.</p>
  </header>

  <%= render "ui/card", padding: :sm do %>
    <%= form_with url: update_account_password_path, method: :patch, class: "space-y-4" do |form| %>
      <%= render "ui/input",
            form: form, field: :current_password, type: :password, label: "Current password",
            placeholder: "••••••••",
            required: true, autocomplete: "current-password" %>

      <%= render "ui/input",
            form: form, field: :password, type: :password, label: "New password",
            placeholder: "••••••••",
            required: true, autocomplete: "new-password",
            minlength: 8, maxlength: 72,
            hint: "At least 8 characters." %>

      <%= render "ui/input",
            form: form, field: :password_confirmation, type: :password, label: "Confirm new password",
            placeholder: "••••••••",
            required: true, autocomplete: "new-password",
            minlength: 8, maxlength: 72 %>

      <button type="submit" class="ui-btn-primary ui-btn-md w-full">Update password</button>
    <% end %>
  <% end %>

  <% unless hotwire_native_app? %>
    <p class="text-sm text-muted-foreground text-center">
      <%= link_to "Back to Dashboard", dashboard_path, class: "ui-btn-link" %>
    </p>
  <% end %>
</div>
