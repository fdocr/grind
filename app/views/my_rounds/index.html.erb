<% content_for :seo_title, "My Rounds" %>

<div class="space-y-6">
  <header class="space-y-1">
    <h1 class="text-xl font-bold text-foreground">My Rounds</h1>
    <p class="text-sm text-muted-foreground">Your finished rounds, most recent first.</p>
  </header>

  <% if @rounds.any? %>
    <div class="space-y-3">
      <% @rounds.each do |round| %>
        <%= link_to round_path(round.token), class: "block" do %>
          <%= render "ui/card", padding: :sm do %>
            <div class="flex items-center justify-between gap-3">
              <div class="min-w-0">
                <p class="font-medium text-foreground truncate"><%= round.course.name %></p>
                <p class="text-sm text-muted-foreground">
                  <%= round.finished_at&.strftime("%b %-d, %Y") %>
                  <% if round.tee_label %>
                    · <%= round.tee_label %> tee
                  <% end %>
                </p>
              </div>
              <p class="text-lg font-bold text-primary-600 shrink-0"><%= format_score_to_par(round.score_to_par) %></p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render "ui/card" do %>
      <%= render "ui/empty_state",
            title: "No rounds yet",
            message: "Finish a round while signed in and it will show up here.",
            icon: "scorecard" %>
    <% end %>
  <% end %>
</div>
