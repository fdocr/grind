<% content_for :seo_description, "Track your golf score and simple stats on your phone. Finish your round and get a free stats email — no account required." %>

<div class="space-y-6">
  <div class="space-y-3">
    <p class="text-muted-foreground">
      Amateurs don't get the same value from stats you commonly see on TV or YouTube. They are built around a game most of us don't play.
    </p>
    <p class="text-muted-foreground">
      Grind is a deliberately simple tool: track a round on your phone, finish, and get a clear picture of where are your misses are coming from.
    </p>
    <p class="text-muted-foreground">
      <%= link_to "Learn more about these game improvement stats", about_path, class: "ui-btn-link" %>.
    </p>
    <p class="text-muted-foreground">
      We'll email the result to your inbox for free and no registration needed. You can create an account for free though and enjoy some niceties. Grind is also <%= link_to "open source", "https://github.com/fdocr/grind", class: "ui-btn-link", target: "_blank", rel: "noopener" %>.
    </p>
  </div>

  <section data-controller="ongoing-rounds" class="hidden space-y-3">
    <h2 class="text-lg font-semibold">Ongoing rounds</h2>
    <div class="space-y-3" data-ongoing-rounds-target="list"></div>

    <template data-ongoing-rounds-target="continueIcon"><%= icon "play", class: "w-5 h-5" %></template>
    <template data-ongoing-rounds-target="clearIcon"><%= icon "trash", class: "w-5 h-5" %></template>

    <div class="hidden" data-ongoing-rounds-target="confirm">
      <div class="fixed inset-0 z-40 bg-black/40" data-action="ongoing-rounds#cancelClear"></div>
      <div class="fixed inset-x-4 bottom-4 z-50">
        <%= render "ui/card", padding: :sm do %>
          <h3 class="font-semibold mb-2">Clear ongoing round?</h3>
          <p class="text-sm text-muted-foreground mb-4">
            This removes your saved scores for <span class="font-medium text-foreground" data-ongoing-rounds-target="confirmName"></span>. This cannot be undone.
          </p>
          <div class="flex gap-2">
            <button type="button" class="ui-btn-secondary ui-btn-md flex-1" data-action="ongoing-rounds#cancelClear">Cancel</button>
            <button type="button" class="ui-btn-danger ui-btn-md flex-1" data-action="ongoing-rounds#confirmClear">Clear round</button>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-3">Find your golf course</h2>
    <%= turbo_frame_tag "course_results" do %>
      <%= render "search_form", query: @query %>
      <%= render "results", courses: @courses, query: @query, featured: @featured, more_results: @more_results %>
    <% end %>
  </section>

  <%= turbo_frame_tag "course_modal" %>

  <section class="mt-32 space-y-6">
    <h1 class="text-5xl font-bold text-foreground text-center">Features</h1>

    <figure class="space-y-6">
      <figcaption class="text-lg text-muted-foreground text-center mt-16">Round tracker on your phone.</figcaption>
      <%= image_tag "sample_tracking.png", alt: "Grind round tracker on a phone", class: "w-full rounded-lg border border-border shadow-card" %>
    </figure>

    <figure class="space-y-6">
      <figcaption class="text-lg text-muted-foreground text-center mt-16">Free stats email when you finish.</figcaption>
      <%= image_tag "sample_email.png", alt: "Round stats email", class: "w-full rounded-lg border border-border shadow-card" %>
    </figure>
  </section>
</div>
