<header class="border-b border-border bg-card relative z-30">
  <div class="max-w-lg mx-auto px-4 py-4 flex items-center justify-between">
    <%= link_to root_path, class: "text-xl font-bold text-primary-700 tracking-tight" do %>
      Grind
    <% end %>

    <div data-controller="nav-menu" class="ui-nav-menu relative">
      <button type="button"
              name="menu"
              aria-label="Open menu"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls="nav-menu-panel"
              class="ui-icon-btn"
              data-testid="nav-menu-button"
              data-nav-menu-target="button"
              data-action="click->nav-menu#toggle">
        <%= render "shared/svg/menu", class: "w-5 h-5" %>
      </button>

      <div id="nav-menu-panel"
           data-nav-menu-target="menu"
           data-testid="nav-menu-panel"
           class="ui-nav-menu-panel hidden"
           role="menu"
           aria-label="Main navigation"
           aria-hidden="true">
        <%= link_to "Home", root_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>

        <% if authenticated? %>
          <%= link_to "My Rounds", my_rounds_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
          <% if current_user.admin? %>
            <%= link_to "Users", admin_users_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
            <%= link_to "Courses", admin_courses_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
            <%= link_to "Contributions", admin_contributions_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
            <%= link_to "Jobs", mission_control_jobs_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
          <% end %>
        <% else %>
          <%= link_to "Sign in", new_session_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
          <%= link_to "Sign up", new_registration_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>
        <% end %>

        <hr class="ui-nav-sep">

        <%= link_to "About", about_path, class: "ui-nav-link", role: "menuitem", data: { turbo: false, action: "click->nav-menu#close" } %>

        <% if authenticated? %>
          <hr class="ui-nav-sep">
          <%= button_to "Sign out",
                session_path,
                method: :delete,
                class: "ui-nav-link-danger",
                role: "menuitem",
                data: { testid: "nav-sign-out" },
                form: { data: { turbo: false } } %>
        <% end %>
      </div>
    </div>
  </div>
</header>
