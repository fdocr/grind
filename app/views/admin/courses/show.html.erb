<% content_for :seo_title, @course.name %>

<div class="space-y-6">
  <header class="space-y-3">
    <% unless hotwire_native_app? %>
      <p class="text-sm text-muted-foreground">
        <%= link_to "← Courses", admin_courses_path, class: "ui-btn-link" %>
      </p>
    <% end %>
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0 space-y-1">
        <h1 class="text-xl font-bold text-foreground"><%= @course.name %></h1>
        <p class="text-sm text-muted-foreground"><%= @course.location_label %></p>
      </div>
      <div class="flex flex-col gap-2 shrink-0">
        <%= link_to "Edit", edit_admin_course_path(@course), class: "ui-btn-secondary ui-btn-md" %>
        <%= button_to "Delete",
              admin_course_path(@course),
              method: :delete,
              class: "ui-btn-danger ui-btn-md",
              form: { data: { turbo: false } },
              data: { turbo_confirm: "Delete #{@course.name}? This also removes #{@course.rounds.count} round(s)." } %>
      </div>
    </div>
  </header>

  <%= render "ui/card", padding: :sm do %>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <% [
        ["Address", @course.address],
        ["Phone", @course.phone],
        ["Website", @course.website],
        ["Coordinates", (@course.coordinates? ? "#{@course.latitude}, #{@course.longitude}" : nil)],
        ["Units", @course.metric? ? "Meters" : "Yards"],
        ["Rounds played", @course.rounds.count]
      ].each do |label, value| %>
        <div>
          <dt class="text-muted-foreground"><%= label %></dt>
          <dd class="font-medium text-foreground mt-0.5">
            <% if label == "Website" && value.present? %>
              <%= link_to value, value, class: "ui-btn-link", target: "_blank", rel: "noopener" %>
            <% else %>
              <%= value.presence || "—" %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  <% end %>

  <%= render "osm_map", course: @course %>

  <% if @active_tee.present? %>
    <section>
      <h2 class="text-lg font-semibold mb-3">Scorecard</h2>
      <%= render "scorecard",
            course: @course,
            holes: @holes,
            tee_names: @tee_names,
            active_tee: @active_tee %>
    </section>
  <% else %>
    <%= render "ui/card" do %>
      <%= render "ui/empty_state",
            title: "No scorecard data",
            message: "Edit this course to add tees and hole details.",
            compact: true %>
    <% end %>
  <% end %>
</div>
