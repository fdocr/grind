<%# locals: (url:, value:, placeholder: "Search", frame: nil, submit_text: "Search") %>
<%= form_with url: url, method: :get, data: ({ turbo_frame: frame } if frame), class: "ui-search-bar" do |f| %>
  <div class="relative flex-1">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground pointer-events-none">
      <%= icon "search", class: "w-5 h-5" %>
    </span>
    <%= f.text_field :q,
          value: value,
          placeholder: placeholder,
          class: "ui-input pl-10" %>
  </div>
  <%= f.submit submit_text, class: "ui-btn-primary ui-btn-md w-full sm:w-auto" %>
<% end %>
