<% content_for :seo_title, @user.email %>

<div class="space-y-6">
  <header class="space-y-1">
    <% unless hotwire_native_app? %>
      <p class="text-sm text-muted-foreground">
        <%= link_to "← Users", admin_users_path, class: "ui-btn-link" %>
      </p>
    <% end %>
    <h1 class="text-xl font-bold text-foreground"><%= @user.email %></h1>
    <%= render "ui/badge",
          text: @user.role.titleize,
          tone: @user.admin? ? :info : (@user.banned? ? :danger : :neutral) %>
  </header>

  <% unless @user == current_user %>
    <%= render "ui/card", padding: :sm do %>
      <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "space-y-4", data: { turbo: false } do |f| %>
        <div class="space-y-2">
          <%= f.label :role, "Role", class: "ui-label" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "ui-select w-full" %>
        </div>
        <button type="submit" class="ui-btn-primary ui-btn-md w-full">Update role</button>
      <% end %>
    <% end %>
  <% end %>

  <section>
    <h2 class="text-lg font-semibold mb-3">Rounds</h2>
    <% if @rounds.any? %>
      <div class="space-y-3">
        <% @rounds.each do |round| %>
          <%= link_to round_path(round.token), class: "block" do %>
            <%= render "ui/card", padding: :sm do %>
              <div class="flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <p class="font-medium text-foreground truncate"><%= round.course.name %></p>
                  <p class="text-sm text-muted-foreground"><%= round.finished_at&.strftime("%b %-d, %Y") %></p>
                </div>
                <p class="text-lg font-bold text-primary-600 shrink-0"><%= format_score_to_par(round.score_to_par) %></p>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "ui/card" do %>
        <%= render "ui/empty_state", title: "No rounds", message: "This user hasn't finished any rounds yet.", compact: true %>
      <% end %>
    <% end %>
  </section>
</div>
