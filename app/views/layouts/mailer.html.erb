<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
        line-height: 1.5;
        margin: 0;
        padding: 24px 16px;
        background: #f8fafc;
        -webkit-text-size-adjust: 100%;
      }

      .email-shell {
        max-width: 560px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
      }

      .email-shell-body {
        padding: 24px 20px;
      }

      .email-container {
        width: 100%;
      }

      .email-header {
        padding-bottom: 20px;
      }

      .email-title {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 4px;
        color: #0f172a;
        line-height: 1.25;
      }

      .email-subtitle {
        margin: 0;
        color: #64748b;
        font-size: 14px;
      }

      .email-hero-stat {
        padding: 20px 16px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        text-align: center;
      }

      .email-hero-label {
        margin: 0 0 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #64748b;
      }

      .email-hero-value {
        margin: 0;
        font-size: 40px;
        font-weight: 700;
        color: #276f54;
        line-height: 1;
      }

      .email-stat-grid {
        padding-top: 16px;
      }

      .email-stat-cell {
        padding: 4px;
      }

      .email-stat-cell--spacer {
        display: none;
      }

      .email-stat-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
      }

      .email-stat-card-body {
        padding: 14px 12px;
        text-align: center;
      }

      .email-stat-value {
        margin: 0 0 4px;
        font-size: 24px;
        font-weight: 700;
        color: #276f54;
        line-height: 1.1;
      }

      .email-stat-label {
        margin: 0;
        font-size: 12px;
        color: #64748b;
        line-height: 1.3;
      }

      .email-footer {
        color: #94a3b8;
        margin: 28px 0 0;
        padding-top: 20px;
        border-top: 1px solid #e2e8f0;
        font-size: 13px;
        text-align: center;
      }

      .email-footer a,
      .email-footer-link {
        color: #276f54;
        text-decoration: none;
        font-weight: 600;
      }

      table.scorecard {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 16px;
        font-size: 13px;
      }

      table.scorecard th,
      table.scorecard td {
        border: 1px solid #e2e8f0;
        padding: 8px 4px;
        text-align: center;
      }

      table.scorecard th {
        background: #f1f5f9;
        font-weight: 600;
      }

      .scorecard-heading {
        font-size: 16px;
        font-weight: 600;
        margin: 24px 0 8px;
        color: #0f172a;
      }

      @media only screen and (max-width: 480px) {
        body {
          padding: 12px 8px;
        }

        .email-shell-body {
          padding: 20px 14px;
        }

        .email-title {
          font-size: 20px;
        }

        .email-hero-value {
          font-size: 34px;
        }

        .email-stat-cell {
          display: block;
          width: 100% !important;
          padding: 4px 0;
        }

        .email-stat-value {
          font-size: 22px;
        }

        table.scorecard {
          font-size: 12px;
        }

        table.scorecard th,
        table.scorecard td {
          padding: 6px 2px;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-shell">
      <div class="email-shell-body">
        <%= yield %>
      </div>
    </div>
  </body>
</html>
