<% content_for :seo_title, @course.name %>
<% content_for :seo_description, "Track your round at #{@course.name} with Grind." %>
<%
  holes_json = @holes.map { |hole| { number: hole.number, par: hole.par, handicap: hole.handicap, yardage: @course.tee_yardage(@tee, hole.number), green: hole.green_geometry.presence } }
  course_json = { id: @course.id, name: @course.name, unit: @course.metric? ? "m" : "yds", holes: holes_json }
%>

<div class="space-y-6"
     data-controller="round"
     data-round-tee-value="<%= @tee %>"
     data-round-course-value="<%= course_json.to_json %>">
  <header class="space-y-1">
    <% unless hotwire_native_app? %>
      <h1 class="text-xl font-bold text-foreground"><%= @course.name %></h1>
    <% end %>
    <div class="flex items-center gap-2 flex-wrap">
      <p class="text-sm text-muted-foreground"><%= Time.zone.today.strftime("%a %b %-d, %Y") %></p>
      <% if @tee.present? %>
        <span class="ui-badge ui-badge-primary ui-badge-sm"><%= @tee.titleize %> tee</span>
      <% end %>
    </div>
    <div class="flex items-start justify-between pt-2 gap-4">
      <div>
        <p class="text-lg font-semibold" data-round-target="holeNumber">1st hole</p>
        <p class="text-sm text-muted-foreground mt-1" data-round-target="holeMeta">Par 4 · Hcp 1</p>
      </div>
      <div class="text-right shrink-0">
        <p class="text-xs text-muted-foreground">Score</p>
        <p class="text-2xl font-bold text-primary-600" data-round-target="scoreToPar">Even</p>
      </div>
    </div>
  </header>

  <div class="grid grid-cols-1 gap-3">
    <button type="button" class="ui-btn-primary ui-btn-md w-full" data-action="round#openScorePanel">Post Score</button>
    <button type="button" class="ui-btn-secondary ui-btn-md w-full" data-action="round#openDistancesPanel">Distances</button>
    <button type="button" class="ui-btn-secondary ui-btn-md w-full" data-action="round#openHolesPanel">Holes</button>
    <button type="button" class="ui-btn-secondary ui-btn-md w-full" data-action="round#openScorecardPanel">Scorecard</button>
    <button type="button"
            class="ui-btn-primary ui-btn-md w-full"
            data-round-target="finishButton"
            data-action="round#finishRound"
            disabled>
      Finish round
    </button>
  </div>

  <section>
    <h2 class="text-sm font-semibold text-muted-foreground mb-3">Round stats</h2>
    <%= render "ui/card", padding: :sm do %>
      <div class="space-y-4">
        <% [
          ["OOP Tee Shots", "oopTeeShots", "oopTeeShots", false],
          ["3 Putts", "threePutts", nil, true],
          ["Botched Up/Down", "botchedUpDowns", "botchedUpDowns", false],
          ["Inside PW/9i", "insidePw9i", "insidePw9i", false]
        ].each do |label, target, stat, readonly| %>
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm font-medium"><%= label %></span>
            <% if readonly %>
              <div class="flex items-center gap-2">
                <span class="inline-flex h-11 w-11 shrink-0" aria-hidden="true"></span>
                <span class="w-10 text-center text-lg font-semibold" data-round-target="<%= target %>">0</span>
                <span class="inline-flex h-11 w-11 shrink-0" aria-hidden="true"></span>
              </div>
            <% else %>
              <div class="flex items-center gap-2">
                <button type="button" class="ui-icon-btn" data-action="round#decrement" data-stat="<%= stat %>" aria-label="Decrease <%= label %>">
                  <%= icon "minus", class: "w-5 h-5" %>
                </button>
                <span class="w-10 text-center text-lg font-semibold" data-round-target="<%= target %>">0</span>
                <button type="button" class="ui-icon-btn" data-action="round#increment" data-stat="<%= stat %>" aria-label="Increase <%= label %>">
                  <%= icon "plus", class: "w-5 h-5" %>
                </button>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
    <p class="hidden mt-2 flex items-center justify-center gap-1.5 text-xs text-muted-foreground"
       data-round-target="statsLastHole"
       aria-live="polite">
      <%= icon "pencil", class: "w-3.5 h-3.5 shrink-0" %>
      <span data-round-target="statsLastHoleLabel">1st hole</span>
    </p>
  </section>

  <div class="flex gap-3">
    <button type="button" class="ui-btn-secondary ui-btn-md flex-1" data-action="round#previousHole">
      <%= icon "chevron_left", class: "w-5 h-5" %>
      Prev
    </button>
    <button type="button" class="ui-btn-secondary ui-btn-md flex-1" data-action="round#nextHole">
      Next
      <%= icon "chevron_right", class: "w-5 h-5" %>
    </button>
  </div>

  <button type="button"
          class="ui-btn-ghost ui-btn-md w-full text-destructive"
          data-action="round#openResetPanel">
    Reset round
  </button>

  <div class="pt-2">
    <%= render "shared/contribute_link", course: @course, style: :button %>
  </div>

  <%= form_with url: course_rounds_path(@course), method: :post, data: { round_target: "finishForm", action: "turbo:submit-end->round#submitEnd" }, class: "hidden" do %>
    <input type="hidden" name="round[oop_tee_shots]" value="0">
    <input type="hidden" name="round[botched_up_downs]" value="0">
    <input type="hidden" name="round[inside_pw_9i]" value="0">
    <input type="hidden" name="round[started_at]" value="" data-round-target="startedAt">
    <input type="hidden" name="round[tee]" value="<%= @tee %>">
    <div data-round-hole-scores></div>
  <% end %>

  <%# -m-24 bleeds the backdrop past the viewport so it also covers the iOS
      home-indicator safe-area strip (a plain inset-0 fixed element stops above
      it in the native web view). The overflow is clipped by the device. %>
  <div class="fixed inset-0 -m-24 z-40 hidden bg-black/40" data-round-target="overlay" data-action="click->round#closePanels"></div>

  <div class="fixed inset-x-4 bottom-4 z-50 hidden" data-round-target="scorePanel">
    <%= render "ui/card", padding: :sm do %>
      <h3 class="font-semibold mb-3">Post score</h3>
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="ui-badge ui-badge-primary ui-badge-sm" data-round-target="scorePanelHole">Hole 1</span>
        <span class="ui-badge ui-badge-neutral ui-badge-sm" data-round-target="scorePanelPar">Par 4</span>
        <span class="ui-badge ui-badge-neutral ui-badge-sm" data-round-target="scorePanelHcp">Hcp 1</span>
        <span class="ui-badge ui-badge-neutral ui-badge-sm hidden" data-round-target="scorePanelYards">—</span>
      </div>
      <div class="space-y-4">
        <div class="ui-picker-row">
          <span class="ui-label">Score</span>
          <div class="ui-picker-scroll" data-round-target="grossPicker" data-action="click->round#pickGross"></div>
          <input type="hidden" data-round-target="grossInput">
        </div>
        <div class="ui-picker-row">
          <span class="ui-label">Putts</span>
          <div class="ui-picker-scroll" data-round-target="puttsPicker" data-action="click->round#pickPutts"></div>
          <input type="hidden" data-round-target="puttsInput">
        </div>
        <div class="flex gap-2 pt-1">
          <button type="button" class="ui-btn-secondary ui-btn-md flex-1" data-action="round#closePanels">Cancel</button>
          <button type="button" class="ui-btn-primary ui-btn-md flex-1" data-action="round#saveHoleScore">Save</button>
        </div>
      </div>
    <% end %>
  </div>

  <div class="fixed inset-x-4 bottom-4 z-50 hidden" data-round-target="distancesPanel"
       data-controller="distances"
       data-distances-unit-value="<%= @course.metric? ? "m" : "yds" %>">
    <%= render "ui/card", padding: :sm do %>
      <div class="flex items-center justify-between mb-4 gap-3">
        <div class="ui-segmented" role="group" aria-label="Distance unit">
          <button type="button" class="ui-segmented-option" data-distances-target="unitOption" data-value="yds" data-action="distances#setUnit">yds</button>
          <button type="button" class="ui-segmented-option" data-distances-target="unitOption" data-value="m" data-action="distances#setUnit">m</button>
        </div>
        <button type="button" class="ui-btn-ghost ui-btn-sm" data-action="round#closePanels">Close</button>
      </div>

      <div class="hidden" data-distances-target="content">
        <div class="flex items-stretch justify-center gap-5 my-8">
          <div class="flex h-40 w-40 shrink-0 items-center justify-center rounded-full border-4 border-primary-500">
            <span class="text-4xl font-bold leading-none text-primary-600" data-distances-target="center">—</span>
          </div>

          <div class="flex flex-col justify-between">
            <div class="-translate-y-2">
              <p class="text-xs uppercase tracking-wide text-muted-foreground">Back</p>
              <p class="text-xl font-semibold text-foreground" data-distances-target="back">—</p>
            </div>
            <div class="translate-y-2">
              <p class="text-xs uppercase tracking-wide text-muted-foreground">Front</p>
              <p class="text-xl font-semibold text-foreground" data-distances-target="front">—</p>
            </div>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-2 text-center" data-distances-target="accuracy"></p>
      </div>

      <div class="hidden py-6 text-center" data-distances-target="tooFar">
        <p class="text-base font-medium text-foreground">You're too far away from the hole</p>
        <p class="text-sm text-muted-foreground mt-1">Distances will appear here once you're closer</p>
      </div>

      <div class="hidden py-2 text-center space-y-3" data-distances-target="status">
        <p class="text-sm text-muted-foreground" data-distances-target="statusMessage">Finding your location…</p>
        <button type="button" class="ui-btn-secondary ui-btn-sm" data-action="distances#retry">Try again</button>
      </div>

      <div class="hidden" data-distances-target="empty">
        <%= render "ui/empty_state",
              title: "No map data for this hole yet",
              message: "We don't have OpenStreetMap green data for this hole.",
              icon: "location" %>
      </div>

      <p class="text-[11px] text-muted-foreground mt-4 text-center">Map data © OpenStreetMap contributors</p>
    <% end %>
  </div>

  <div class="fixed inset-x-4 bottom-4 z-50 hidden max-h-[70vh] overflow-y-auto" data-round-target="holesPanel">
    <%= render "ui/card", padding: :sm do %>
      <h3 class="font-semibold mb-4">Select hole</h3>
      <div data-round-target="holesList"></div>
    <% end %>
  </div>

  <template data-round-target="holeScoredIcon">
    <%= icon "check", class: "w-3.5 h-3.5 shrink-0 text-primary-600" %>
  </template>

  <div class="fixed inset-x-4 bottom-4 z-50 hidden max-h-[80vh] overflow-y-auto overflow-x-hidden" data-round-target="scorecardPanel">
    <%= render "ui/card", padding: :sm, extra_class: "overflow-hidden" do %>
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold">Scorecard</h3>
        <button type="button" class="ui-btn-ghost ui-btn-sm" data-action="round#closePanels">Close</button>
      </div>
      <div class="min-w-0" data-round-target="scorecardBody"></div>
      <div class="mt-4 pt-4 border-t border-border">
        <%= render "shared/contribute_link", course: @course, style: :link %>
      </div>
    <% end %>
  </div>

  <div class="fixed inset-x-4 bottom-4 z-50 hidden" data-round-target="resetPanel">
    <%= render "ui/card", padding: :sm do %>
      <h3 class="font-semibold mb-2">Reset round?</h3>
      <p class="text-sm text-muted-foreground mb-4">
        This clears all scores and stats for this round. This cannot be undone.
      </p>
      <div class="flex gap-2">
        <button type="button" class="ui-btn-secondary ui-btn-md flex-1" data-action="round#closePanels">Cancel</button>
        <button type="button" class="ui-btn-danger ui-btn-md flex-1" data-action="round#confirmReset">Reset round</button>
      </div>
    <% end %>
  </div>
</div>
